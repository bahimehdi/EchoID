# EchoID shared Docker environment.
# Copy this file to infra/env/.env and replace every CHANGE_ME before sharing.

# --- PostgreSQL ---
# REQUIRED: database name created by the postgres container.
POSTGRES_DB=echoid
# REQUIRED: database user created by the postgres container.
POSTGRES_USER=echoid_user
# REQUIRED: database password. Use a real secret outside local-only dev.
POSTGRES_PASSWORD=CHANGE_ME

# --- Backend (Spring Boot) ---
# Optional: backend port. Default local convention is 8080.
SERVER_PORT=8080
# REQUIRED for Docker: JDBC URL must use the postgres service name.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/echoid
# REQUIRED for Docker: should match POSTGRES_USER.
SPRING_DATASOURCE_USERNAME=echoid_user
# REQUIRED for Docker: should match POSTGRES_PASSWORD.
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# --- Backend security ---
# REQUIRED: replace with a strong secret before any shared environment.
JWT_SECRET=CHANGE_ME
# Optional: one day in milliseconds.
JWT_EXPIRY_MS=86400000

# Required for real Google login. Placeholders are enough for health checks.
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# Backend to AI service. Use the Compose service name inside Docker.
AI_SERVICE_URL=http://ai-service:8000

# Comma-separated browser origins allowed by the backend.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- AI Service (FastAPI) ---
# Optional: FastAPI port. Docker currently starts Uvicorn on 8000.
PORT=8000
# REQUIRED when Sprint 2 live LLM calls are enabled. Generic/provider-neutral name.
LLM_API_KEY=CHANGE_ME
# REQUIRED when Gemini calls are enabled. Matches the AI engineer branch convention.
GOOGLE_API_KEY=CHANGE_ME
# REQUIRED when Sprint 2 YouTube recommendations are enabled.
YOUTUBE_API_KEY=CHANGE_ME
# Optional OCR language hint for future OCR processing.
OCR_LANGUAGE_HINT=en

# AI service to backend. Use the Compose service name inside Docker.
BACKEND_URL=http://backend:8080

# --- Grafana ---
# REQUIRED: initial local Grafana admin password.
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
