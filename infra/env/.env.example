# --- PostgreSQL ---
POSTGRES_DB=echoid
POSTGRES_USER=echoid_user
POSTGRES_PASSWORD=CHANGE_ME

# --- Backend (Spring Boot) ---
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/echoid
SPRING_DATASOURCE_USERNAME=echoid_user
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# JWT
JWT_SECRET=CHANGE_ME
JWT_EXPIRY_MS=86400000

# OAuth2 (dev placeholders are enough for health checks)
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# Backend to AI service
AI_SERVICE_URL=http://ai-service:8000

# CORS
CORS_ALLOWED_ORIGIN=http://localhost:3000

# --- AI Service (FastAPI) ---
PORT=8000
LLM_API_KEY=CHANGE_ME
YOUTUBE_API_KEY=CHANGE_ME
OCR_LANGUAGE_HINT=en

# AI service to backend
BACKEND_URL=http://backend:8080

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
