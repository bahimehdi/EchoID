{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Admin — Platform Health",
  "uid": "admin",
  "tags": ["echoid", "admin"],
  "schemaVersion": 39,
  "time": { "from": "now-14d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "school",
        "type": "custom",
        "current": { "text": "All", "value": "All" },
        "options": [
          { "text": "All", "value": "All", "selected": true },
          { "text": "ENSA", "value": "ENSA" },
          { "text": "EST", "value": "EST" },
          { "text": "FAC", "value": "FAC" }
        ],
        "query": "All,ENSA,EST,FAC",
        "label": "School"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active students (14 d)",
      "datasource": { "type": "postgres", "uid": "EchoID-PG" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT student_id) FROM v_session_engagement WHERE ($school = 'All' OR school::text = '$school');",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "OCR uploads (week)",
      "datasource": { "type": "postgres", "uid": "EchoID-PG" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(SUM(upload_count), 0) FROM v_ocr_usage_per_professor WHERE week >= NOW() - INTERVAL '7 days';",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Notifications sent (week)",
      "datasource": { "type": "postgres", "uid": "EchoID-PG" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(SUM(sent_count), 0) FROM v_notifications_sent WHERE day >= NOW() - INTERVAL '7 days';",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Notification read rate",
      "datasource": { "type": "postgres", "uid": "EchoID-PG" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "rawSql": "SELECT CASE WHEN SUM(sent_count)=0 THEN 0 ELSE ROUND(100.0 * SUM(read_count) / SUM(sent_count), 1) END AS pct FROM v_notifications_sent;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "barchart",
      "title": "Active students by school (14 d)",
      "datasource": { "type": "postgres", "uid": "EchoID-PG" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 9 },
      "targets": [
        {
          "rawSql": "SELECT school::text AS school, COUNT(DISTINCT student_id) AS students FROM v_session_engagement GROUP BY school;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Notifications sent (daily, by trigger)",
      "datasource": { "type": "postgres", "uid": "EchoID-PG" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 9 },
      "targets": [
        {
          "rawSql": "SELECT day AS time, trigger_type AS metric, sent_count AS value FROM v_notifications_sent ORDER BY day;",
          "format": "time_series",
          "refId": "A"
        }
      ]
    }
  ]
}
