# Optional local-only AI service environment.
# Docker Compose uses infra/env/.env instead.
# Copy this file to ai-service/.env only when running FastAPI outside Docker.
# Never commit a real .env file.

# Optional: FastAPI port for local runs.
PORT=8000

# REQUIRED when Sprint 2 live LLM calls are enabled. Generic/provider-neutral name.
LLM_API_KEY=CHANGE_ME

# REQUIRED when Gemini calls are enabled. Matches the AI engineer branch convention.
GOOGLE_API_KEY=CHANGE_ME

# REQUIRED when Sprint 2 YouTube recommendations are enabled.
YOUTUBE_API_KEY=CHANGE_ME

# Optional OCR language hint for future OCR processing.
OCR_LANGUAGE_HINT=en

# URL of the Spring Boot backend when running AI locally on the host.
BACKEND_URL=http://localhost:8080
