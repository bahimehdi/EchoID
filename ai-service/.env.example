# Copy this file to .env and fill in real values.
# NEVER commit .env to GitHub — only commit .env.example.

# ── Sprint 2 keys (get these before Sprint 2 starts) ──────────

# Gemini Flash (free) — aistudio.google.com -> Get API Key
GOOGLE_API_KEY=

# YouTube Data API (free) — console.cloud.google.com -> Enable YouTube Data API v3
YOUTUBE_API_KEY=

# ── Backend connection ─────────────────────────────────────────
# URL of the Spring Boot backend (for CORS in production)
BACKEND_URL=http://localhost:8000
